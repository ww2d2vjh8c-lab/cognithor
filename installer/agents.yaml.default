  description: E-Mail-Triage, Kalender-Management, Dokument-Erstellung, Meeting-Vorbereitung
    und organisatorische Aufgaben. Schnelles 8b-Modell fuer effiziente Alltagsaufgaben.
  display_name: Office
  enabled: true
  language: de
  max_delegation_depth: 2
  name: office
  preferred_model: qwen3:8b
  priority: 3
