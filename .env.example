# ============================================================================
# Cognithor · Agent OS — Environment Variables (Optional)
# ============================================================================
# Override config.yaml values. Useful for Docker/Deployment.
# Copy to .env and edit. Loaded by systemd EnvironmentFile.
# ============================================================================

# --- Ollama (Local) ---
# JARVIS_OLLAMA_BASE_URL=http://localhost:11434

# --- User ---
# JARVIS_OWNER_NAME=Max

# --- LLM Backend ---
# JARVIS_LLM_BACKEND_TYPE=ollama
# Supported: ollama | openai | anthropic | gemini | groq | deepseek |
#            mistral | together | openrouter | xai | cerebras | github |
#            bedrock | huggingface | moonshot

# --- API Keys (set the one for your chosen backend) ---
# JARVIS_OPENAI_API_KEY=sk-...
# JARVIS_OPENAI_BASE_URL=https://api.openai.com/v1
# JARVIS_ANTHROPIC_API_KEY=sk-ant-...
# JARVIS_ANTHROPIC_MAX_TOKENS=4096
# JARVIS_GEMINI_API_KEY=AIza...
# JARVIS_GROQ_API_KEY=gsk_...
# JARVIS_DEEPSEEK_API_KEY=sk-...
# JARVIS_MISTRAL_API_KEY=...
# JARVIS_TOGETHER_API_KEY=...
# JARVIS_OPENROUTER_API_KEY=sk-or-...
# JARVIS_XAI_API_KEY=xai-...
# JARVIS_CEREBRAS_API_KEY=csk-...
# JARVIS_GITHUB_MODELS_TOKEN=ghp_...
# JARVIS_BEDROCK_REGION=us-east-1
# JARVIS_HUGGINGFACE_API_KEY=hf_...
# JARVIS_MOONSHOT_API_KEY=sk-...

# --- Logging ---
# JARVIS_LOGGING_LEVEL=INFO

# --- Language ---
# JARVIS_LANGUAGE=de

# --- Models ---
# JARVIS_MODELS_PLANNER=qwen3:32b
# JARVIS_MODELS_EXECUTOR=qwen3:8b
# JARVIS_MODELS_CODER=qwen3:32b
# JARVIS_MODELS_EMBEDDING=nomic-embed-text

# --- LM Studio (Alternative zu Ollama) ---
# JARVIS_LMSTUDIO_BASE_URL=http://localhost:1234
# JARVIS_LMSTUDIO_API_KEY=

# --- Channels ---
# JARVIS_CHANNELS_CLI_ENABLED=true
# JARVIS_CHANNELS_WEBUI_ENABLED=true
# JARVIS_CHANNELS_WEBUI_PORT=8080
# JARVIS_CHANNELS_VOICE_ENABLED=false

# --- Telegram ---
# JARVIS_CHANNELS_TELEGRAM_ENABLED=true
# JARVIS_TELEGRAM_TOKEN=7123456789:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw
# JARVIS_TELEGRAM_ALLOWED_USERS=123456789,987654321
# JARVIS_CHANNELS_TELEGRAM_USE_WEBHOOK=false
# JARVIS_CHANNELS_TELEGRAM_WEBHOOK_URL=
# JARVIS_CHANNELS_TELEGRAM_WEBHOOK_PORT=8443

# --- Discord ---
# JARVIS_CHANNELS_DISCORD_ENABLED=true
# DISCORD_TOKEN=your-discord-bot-token
# JARVIS_CHANNELS_DISCORD_CHANNEL_ID=

# --- Slack ---
# JARVIS_CHANNELS_SLACK_ENABLED=true
# SLACK_BOT_TOKEN=xoxb-your-slack-token
# JARVIS_CHANNELS_SLACK_DEFAULT_CHANNEL=general

# --- Matrix ---
# JARVIS_CHANNELS_MATRIX_ENABLED=true
# MATRIX_ACCESS_TOKEN=your-matrix-token
# JARVIS_CHANNELS_MATRIX_HOMESERVER=https://matrix.org
# JARVIS_CHANNELS_MATRIX_USER_ID=@bot:matrix.org

# --- Microsoft Teams ---
# JARVIS_CHANNELS_TEAMS_ENABLED=true
# TEAMS_APP_ID=your-teams-app-id
# TEAMS_APP_PASSWORD=your-teams-app-password

# --- WhatsApp ---
# JARVIS_CHANNELS_WHATSAPP_ENABLED=true
# WHATSAPP_TOKEN=your-whatsapp-token
# JARVIS_CHANNELS_WHATSAPP_PHONE_NUMBER_ID=
# JARVIS_CHANNELS_WHATSAPP_WEBHOOK_PORT=8444
# JARVIS_CHANNELS_WHATSAPP_VERIFY_TOKEN=
# JARVIS_CHANNELS_WHATSAPP_ALLOWED_NUMBERS=

# --- Signal ---
# JARVIS_CHANNELS_SIGNAL_ENABLED=true
# SIGNAL_PHONE_NUMBER=+49123456789
# JARVIS_CHANNELS_SIGNAL_DEFAULT_USER=

# --- Google Chat ---
# JARVIS_CHANNELS_GOOGLE_CHAT_ENABLED=true
# JARVIS_CHANNELS_GOOGLE_CHAT_CREDENTIALS_PATH=
# JARVIS_CHANNELS_GOOGLE_CHAT_ALLOWED_SPACES=

# --- Mattermost ---
# JARVIS_CHANNELS_MATTERMOST_ENABLED=true
# JARVIS_CHANNELS_MATTERMOST_URL=https://mattermost.example.com
# JARVIS_CHANNELS_MATTERMOST_TOKEN=your-token
# JARVIS_CHANNELS_MATTERMOST_CHANNEL=town-square

# --- Feishu/Lark ---
# JARVIS_CHANNELS_FEISHU_ENABLED=true
# JARVIS_CHANNELS_FEISHU_APP_ID=
# JARVIS_CHANNELS_FEISHU_APP_SECRET=

# --- IRC ---
# JARVIS_CHANNELS_IRC_ENABLED=true
# JARVIS_CHANNELS_IRC_SERVER=irc.libera.chat
# JARVIS_CHANNELS_IRC_PORT=6697
# JARVIS_CHANNELS_IRC_NICK=cognithor
# JARVIS_CHANNELS_IRC_CHANNELS=#channel1,#channel2

# --- Twitch ---
# JARVIS_CHANNELS_TWITCH_ENABLED=true
# JARVIS_CHANNELS_TWITCH_TOKEN=oauth:your-token
# JARVIS_CHANNELS_TWITCH_CHANNEL=yourchannel

# --- iMessage (macOS only) ---
# JARVIS_CHANNELS_IMESSAGE_ENABLED=true

# --- Web Search Providers ---
# JARVIS_WEB_SEARXNG_URL=http://localhost:8888
# JARVIS_WEB_BRAVE_API_KEY=BSA...
# JARVIS_WEB_GOOGLE_CSE_API_KEY=AIza...
# JARVIS_WEB_GOOGLE_CSE_CX=
# JARVIS_WEB_JINA_API_KEY=jina_...

# --- Personality ---
# JARVIS_PERSONALITY_WARMTH=0.7
# JARVIS_PERSONALITY_HUMOR=0.3

# --- Credential-Store Password ---
# If not set, a random one is generated and stored in ~/.cognithor/.credential_key
# JARVIS_CREDENTIAL_PASSPHRASE=your-secure-password-here

# --- Home Directory (Default: ~/.cognithor) ---
# JARVIS_HOME=/opt/cognithor/data

# ============================================================================
# Server Deployment (Docker / Bare-Metal)
# ============================================================================

# --- Control Center API ---
# JARVIS_API_HOST=0.0.0.0
# JARVIS_API_TOKEN=your-secure-api-token-here
# JARVIS_API_CORS_ORIGINS=https://jarvis.example.com

# --- WebUI Channel (standalone via uvicorn --factory) ---
# JARVIS_WEBUI_HOST=0.0.0.0
# JARVIS_WEBUI_CORS_ORIGINS=https://jarvis.example.com

# --- TLS ---
# JARVIS_SSL_CERTFILE=/etc/letsencrypt/live/jarvis.example.com/fullchain.pem
# JARVIS_SSL_KEYFILE=/etc/letsencrypt/live/jarvis.example.com/privkey.pem

# --- PostgreSQL (optional, für pgvector) ---
# JARVIS_POSTGRES_HOST=localhost
# JARVIS_POSTGRES_PORT=5432
# JARVIS_POSTGRES_DB=cognithor
# JARVIS_POSTGRES_USER=cognithor
# JARVIS_POSTGRES_PASSWORD=change-me-in-production
